# provision/mcp-wazuh.env.example
# Copy this file to ~/mcp-wazuh/.env on the wazuh-server VM and fill in your values.
# Never commit the real .env file to version control.

WAZUH_API_HOST=127.0.0.1
WAZUH_API_PORT=55000
WAZUH_API_USERNAME=wazuh-wui
WAZUH_API_PASSWORD=CHANGE_ME

WAZUH_INDEXER_HOST=127.0.0.1
WAZUH_INDEXER_PORT=9200
WAZUH_INDEXER_USERNAME=admin
WAZUH_INDEXER_PASSWORD=CHANGE_ME

WAZUH_VERIFY_SSL=false
WAZUH_TEST_PROTOCOL=https
RUST_LOG=info
