# mcp-wazuh.env.example
#
# Copy this file to .env in the repo root and fill in the values marked
# CHANGE_ME. The Wazuh credentials are the defaults shipped by
# wazuh/wazuh-docker v4.14.0 multi-node and do not need to change if you
# provisioned the VM with `vagrant up` without modifying the Wazuh
# docker-compose.yml.
#
# Never commit the real .env file to version control.

# ── Wazuh API (wazuh-master container inside the VM) ─────────────────────────
WAZUH_API_HOST=192.168.56.110
WAZUH_API_PORT=55000
WAZUH_API_USERNAME=wazuh-wui
WAZUH_API_PASSWORD=MyS3cr37P450r.*-

# ── Wazuh Indexer (OpenSearch inside the VM) ──────────────────────────────────
WAZUH_INDEXER_HOST=192.168.56.110
WAZUH_INDEXER_PORT=9200
WAZUH_INDEXER_USERNAME=admin
WAZUH_INDEXER_PASSWORD=SecretPassword

# ── Wazuh MCP server options ──────────────────────────────────────────────────
WAZUH_VERIFY_SSL=false
WAZUH_TEST_PROTOCOL=https
RUST_LOG=info

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=CHANGE_ME
OPENAI_MODEL=gpt-4o

# ── Framework shared secret (any random string) ───────────────────────────────
# Generate one with: openssl rand -hex 32
MCP_API_KEY=soc-framework-dev-key

# ── Supply chain verification (optional but recommended) ──────────────────────
# Obtain with: docker exec wazuh-mcp sha256sum /app/mcp-server-wazuh
# Set both variables to the same value after the first build.
WAZUH_MCP_BINARY_HASH=
WAZUH_MCP_BINARY_HASH_ACTUAL=
